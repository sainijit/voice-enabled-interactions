# =============================================================================
# Smart Kiosk Assistant — Environment Configuration
# =============================================================================
#
# QUICKSTART:
#   make init-env        # copies this file → .env
#   # edit .env and set HF_TOKEN (the only REQUIRED field)
#   make setup-models    # download the OVMS LLM model (~4 GB)
#   make build           # build Docker images
#   make up              # start the stack  (runs check-env automatically)
#
# LEGEND:
#   [REQUIRED]  — must be set; make up will fail without it
#   [Optional]  — has a safe default; change only if needed
#
# =============================================================================


# =============================================================================
# [REQUIRED] HuggingFace Access Token
# =============================================================================
# Used by:
#   • audio-analyzer — Pyannote speaker diarization (gated model)
#   • setup_models.sh — model download from HuggingFace Hub
#
# Get your token (read-only is fine):
#   https://huggingface.co/settings/tokens
#
# You must also accept the Pyannote model licence at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
# =============================================================================
HF_TOKEN=


# =============================================================================
# [REQUIRED] Inference Device
# =============================================================================
# Target hardware for OVMS LLM and OpenVINO models.
# Allowed values: CPU | GPU | NPU
#
# GPU (Intel iGPU) is strongly recommended for real-time latency.
# Prerequisites for GPU:
#   sudo apt-get install -y intel-opencl-icd level-zero
#   sudo usermod -aG render $USER   # log out and back in
# =============================================================================
TARGET_DEVICE=GPU


# =============================================================================
# [REQUIRED for GPU] Render Group ID
# =============================================================================
# Gives Docker containers access to /dev/dri/renderD* (Intel GPU node).
# Run this command to find the correct value on your machine:
#   getent group render | cut -d: -f3
#
# setup_models.sh sets this automatically if you run it first.
# =============================================================================
RENDER_GID=992


# =============================================================================
# [Optional] OVMS LLM Model
# =============================================================================
# Pre-converted OpenVINO IR model downloaded from HuggingFace Hub by
# setup_models.sh into ./models/
#
# Options:
#   OpenVINO/Qwen3-4B-int8-ov   INT8 ~4 GB — better accuracy  (default)
#   OpenVINO/Qwen3-4B-int4-ov   INT4 ~2 GB — smaller, faster
# =============================================================================
OVMS_MODEL_NAME=OpenVINO/Qwen3-4B-int8-ov


# =============================================================================
# [Optional] Docker Image Registry / Release Tag
# =============================================================================
# REGISTRY=intel  → images tagged as intel/<svc>:<RELEASE_TAG>
# Override via: make build REGISTRY=false   (build locally from source)
#               make build REGISTRY=true    (pull from registry)
# =============================================================================
REGISTRY=intel
RELEASE_TAG=2026.1.0


# =============================================================================
# [Optional] Sample Videos (queue-service RTSP feed)
# =============================================================================
# Downloaded by:  make download-sample-video
#
# SAMPLE_DATA_DIR — destination directory for the downloaded clips. This is the
#   same directory mounted into the rtsp-streamer container (./Sample_data).
#   Files are always saved as sample_1.mp4 / sample_2.mp4 so they match the
#   MEDIA_FILES entry in docker-compose.yml.
#
# SAMPLE_VIDEO_1_URL / SAMPLE_VIDEO_2_URL — direct download URLs for the two
#   clips. The Pexels page links below are provided as a reference; replace them
#   with the corresponding direct .mp4 download URLs (Pexels "Free Download"
#   link) before running 'make download-sample-video'.
#     https://www.pexels.com/video/performance-promoting-equality-concept-10617615/
#     https://www.pexels.com/video/young-people-standing-in-line-to-promote-equality-10617738/
# =============================================================================
SAMPLE_DATA_DIR=/home/intel/jitendra/voice-enabled-interactions/smart-kiosk-assistant/Sample_data
SAMPLE_VIDEO_1_URL=https://www.pexels.com/video/performance-promoting-equality-concept-10617615/
SAMPLE_VIDEO_2_URL=https://www.pexels.com/video/young-people-standing-in-line-to-promote-equality-10617738/
