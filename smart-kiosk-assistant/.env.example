# =============================================================================
# Smart Kiosk Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in required values:
#   cp .env.example .env
#
# Then run:
#   make setup-models    # download the OVMS LLM model (~4 GB)
#   make build           # build Docker images
#   make up              # start the stack
# =============================================================================

# -----------------------------------------------------------------------------
# Docker image registry
# REGISTRY=intel  → images tagged as intel/<svc>:<RELEASE_TAG>
# -----------------------------------------------------------------------------
REGISTRY=intel
RELEASE_TAG=2026.1.0

# -----------------------------------------------------------------------------
# Inference device for the OVMS LLM and OpenVINO models
# Permitted values: CPU | GPU | NPU
# GPU is recommended (Intel iGPU, Meteor Lake or newer).
# Install Intel GPU drivers first: sudo apt-get install intel-opencl-icd level-zero
# -----------------------------------------------------------------------------
TARGET_DEVICE=GPU

# Render group ID — needed for GPU access inside containers.
# Set automatically by setup_models.sh; or run:
#   getent group render | cut -d: -f3
RENDER_GID=992

# -----------------------------------------------------------------------------
# OVMS LLM model
# setup_models.sh downloads this from HuggingFace Hub into ./models/
#   INT8 (~4 GB, default, better accuracy): OpenVINO/Qwen3-4B-int8-ov
#   INT4 (~2 GB, smaller/faster):           OpenVINO/Qwen3-4B-int4-ov
# -----------------------------------------------------------------------------
OVMS_MODEL_NAME=OpenVINO/Qwen3-4B-int8-ov

# -----------------------------------------------------------------------------
# HuggingFace token — REQUIRED
# Used by:
#   1. audio-analyzer: Pyannote speaker diarization (gated model)
#   2. setup_models.sh: model download (if gated)
# Get your token at: https://huggingface.co/settings/tokens
# -----------------------------------------------------------------------------
HF_TOKEN=
